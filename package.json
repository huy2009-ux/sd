{
  "name": "mailbox",
  "version": "2.0.0",
  "description": "Chat, kết bạn và chia sẻ cùng MailBox",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.mailbox.app",
    "productName": "MailBox",
    "icon": "public/icon-512.png",
    "files": [
      "electron-main.js",
      "server.js",
      "public/**/*",
      ".env",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mongoose": "^9.6.3",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.0.0"
  }
}
